# VPS deployment
# Required by CI deploy workflow.
# Keep real values in GitHub Actions secrets, not in tracked files.
# VPS_HOST=user@vps-ip
# VPS_SSH_KEY=replace-with-ssh-private-key
# VPS_USER=deploy
#
# docker-compose.vps.yml uses .env.vps on the VPS (never committed).
# IMAGE_TAG is the immutable image tag for production deploys, e.g. sha-<commit-sha>.
# IMAGE_TAG=sha-0000000

# Application
APP_NAME=pulih-api
APP_ENV=local
NODE_ENV=development
HOST=0.0.0.0
PORT=3002
API_PREFIX=/api/v1
APP_URL=https://pulih-api.salmanabdurrahman.my.id
PWA_URL=http://localhost:3001

# Database
# DATABASE_URL is the runtime database connection for the Bun server (used by the API).
# DIRECT_DATABASE_URL is used for local/CI migrations (drizzle-kit).
# In VPS both can point to the same connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulih_db?sslmode=disable
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulih_db?sslmode=disable

# Production/Supabase example (SSL required):
# DATABASE_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
# DIRECT_DATABASE_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

# Connection pool (VPS runtime)
# DATABASE_POOL_MAX=10
# DATABASE_POOL_IDLE_TIMEOUT_MS=30000

# Auth
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_ACCESS_TTL_SECONDS=86400
PASSWORD_HASH_COST=10

# Security
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:4173

# Observability
REQUEST_ID_HEADER=x-request-id

# Integration placeholders
PAKASIR_PROJECT_SLUG=pulih
PAKASIR_API_KEY=replace-with-pakasir-api-key
PAKASIR_BASE_URL=https://app.pakasir.com
PAKASIR_PAYMENT_BASE_URL=https://app.pakasir.com
PAKASIR_PROVIDER_TIMEOUT_MS=10000
# PAKASIR_WEBHOOK_TOLERANCE_SECONDS=
RESEND_API_KEY=replace-with-resend-api-key
RESEND_FROM_EMAIL=no-reply@salmanabdurrahman.web.id
RESEND_FROM_NAME=Pulih
AI_BASE_URL=https://ai.sumopod.com/v1
AI_API_KEY=replace-with-ai-api-key
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=10000
AI_MAX_TOKENS=800

# File storage — Cloudflare R2 (S3-compatible)
# Create R2 bucket at https://dash.cloudflare.com → R2 → Create bucket
# Then create API token with "Object Read & Write" permission for that bucket
# Endpoint format: https://<account-id>.r2.cloudflarestorage.com
# Region: use "auto" (R2 default)
CREDENTIAL_STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
CREDENTIAL_STORAGE_REGION=auto
CREDENTIAL_STORAGE_BUCKET=pulih-credentials
CREDENTIAL_STORAGE_ACCESS_KEY=<r2-access-key-id>
CREDENTIAL_STORAGE_SECRET_KEY=<r2-secret-access-key>
