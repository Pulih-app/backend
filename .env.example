# Application
APP_NAME=pulih-api
APP_ENV=local
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
APP_URL=http://localhost:3000
PWA_URL=http://localhost:3001

# Database
# Use DIRECT_DATABASE_URL for local/CI migrations.
# Hyperdrive binding is used in Cloudflare Workers runtime.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulih_db?sslmode=disable
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulih_db?sslmode=disable

# Auth
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_ACCESS_TTL_SECONDS=86400
PASSWORD_HASH_COST=10

# Security
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:4173

# Observability
REQUEST_ID_HEADER=x-request-id

# Future integration placeholders
# HYPERDRIVE binding is configured in wrangler.toml
# R2_CREDENTIAL_BUCKET binding is configured in wrangler.toml
PAKASIR_PROJECT_SLUG=pulih
PAKASIR_API_KEY=replace-with-pakasir-api-key
PAKASIR_BASE_URL=https://app.pakasir.com
PAKASIR_PAYMENT_BASE_URL=https://app.pakasir.com
PAKASIR_PROVIDER_TIMEOUT_MS=10000
